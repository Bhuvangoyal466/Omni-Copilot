APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000
CORS_ALLOW_ORIGINS=http://localhost:3000
FRONTEND_APP_URL=http://localhost:3000
OAUTH_REDIRECT_BASE_URL=http://localhost:3000

GROQ_API_KEY=
GROQ_TTS_MODEL=playai-tts
GROQ_TTS_VOICE_EN=alloy
GROQ_TTS_VOICE_HI=alloy
GROQ_TTS_VOICE_EN_FEMALE=alloy
GROQ_TTS_VOICE_EN_MALE=onyx
GROQ_TTS_VOICE_HI_FEMALE=alloy
GROQ_TTS_VOICE_HI_MALE=onyx
OPENAI_API_KEY=
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
DEFAULT_MODEL=llama-3.3-70b-versatile
FALLBACK_MODEL=gpt-5.4-mini

UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME?sslmode=require
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=omni_memory

JWT_ISSUER=omni-copilot
JWT_AUDIENCE=omni-copilot-api
JWT_SECRET=replace-with-long-secret

# OAuth apps for tool integrations
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Optional mem0 provider
MEM0_ENABLED=false
MEM0_API_KEY=

# Optional: custom local-disk search roots (separate multiple paths with ';' on Windows)
OMNI_LOCAL_SEARCH_DIRS=

# Optional: keep WhatsApp automation browser visible after send (milliseconds)
OMNI_WHATSAPP_CONFIRMATION_MS=6000
OMNI_WHATSAPP_DESKTOP_WARMUP_MS=1200
OMNI_WHATSAPP_DESKTOP_AUTOMATION=true
OMNI_KEEP_AUTOMATION_WINDOWS_OPEN=false

# Optional: fallback to browser automation when Google Forms API is unavailable
OMNI_GFORMS_ENABLE_BROWSER_FALLBACK=true
OMNI_GFORMS_CONFIRMATION_MS=3500
